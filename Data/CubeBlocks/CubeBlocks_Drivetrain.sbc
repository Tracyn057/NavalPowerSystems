		<Definition>
			<Id>
				<TypeId>TerminalBlock</TypeId>
				<SubtypeId>NPSGearbox_DoublePlanetary</SubtypeId>
			</Id>
			<DisplayName>Double Planetary Reduction Gearbox</DisplayName>
			<Description>Reduction Stages: 2</Description>
			<Icon>Textures\GUI\Icons\Cubes\Gearbox_DoublePlanetary.dds</Icon>
			<CubeSize>Large</CubeSize>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="1" y="1" z="2"/>
			<ModelOffset x="0" y="0" z="0"/>
			<Model>Models\Cubes\large\Gearbox_DoublePlanetary.mwm</Model>
			<Components>
				<Component Subtype="SteelPlate" Count="1100" />
				<Component Subtype="Construction" Count="40" />
